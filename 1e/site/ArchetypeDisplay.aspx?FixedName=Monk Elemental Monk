                  if (e.keyCode == 13) {
                      e.preventDefault();
                      if (text.value != null && text.value.length > 0)
                          window.location = window.location.origin + "/Search.aspx?Query=" + text.value + "&Filter=111111111111111111&AllTerms=True";
